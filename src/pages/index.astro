---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection, render } from "astro:content";

const allPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const allProjects = (await getCollection("projects"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const recentMemos = (await getCollection("memos", ({ data }) => data.confirmed === true))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <section class="mb-12">
    <h1 class="text-xl font-bold mb-2">Hey, I'm Yuho</h1>
    <p class="text-sm text-[--color-text-secondary] leading-relaxed">
      一个 Builder。和 AI 对话，先解决自己的问题，再试着解决别人的。偶尔写点东西。
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-xs text-[--color-text-muted] tracking-widest mb-4">
      最新文章
    </h2>
    {allPosts.map((post) => (
      <PostCard
        title={post.data.title}
        href={`/blog/${post.id}`}
        date={post.data.date}
      />
    ))}
    <a href="/blog" class="text-xs text-[--color-text-secondary] hover:text-[--color-text] no-underline mt-2 inline-block">
      → 全部文章
    </a>
  </section>

  <section class="mb-12">
    <h2 class="text-xs text-[--color-text-muted] tracking-widest mb-4">
      最近碎片
    </h2>
    {recentMemos.map((memo) => {
      const d = memo.data.date;
      const dateStr = d.toLocaleDateString("zh-CN", { month: "2-digit", day: "2-digit" });
      // Use first line of body as preview
      const preview = (memo.body || "").replace(/\[\[([^\]]*?\|)?([^\]]+)\]\]/g, "$2").split("\n").find((l) => l.trim()) || "";
      const truncated = preview.length > 60 ? preview.slice(0, 60) + "…" : preview;
      return (
        <a href="/memos" class="flex items-baseline gap-3 py-1.5 no-underline group">
          <time class="text-xs text-[--color-text-muted] shrink-0">{dateStr}</time>
          <span class="text-sm text-[--color-text-secondary] group-hover:text-[--color-text] transition-colors truncate">{truncated}</span>
        </a>
      );
    })}
    <a href="/memos" class="text-xs text-[--color-text-secondary] hover:text-[--color-text] no-underline mt-2 inline-block">
      → 全部碎片
    </a>
  </section>

  <section>
    <h2 class="text-xs text-[--color-text-muted] tracking-widest mb-4">
      项目
    </h2>
    <div class="grid grid-cols-2 gap-3">
      {allProjects.map((project) => (
        <ProjectCard {...project.data} />
      ))}
    </div>
    <a href="/projects" class="text-xs text-[--color-text-secondary] hover:text-[--color-text] no-underline mt-4 inline-block">
      → 全部项目
    </a>
  </section>
</BaseLayout>
