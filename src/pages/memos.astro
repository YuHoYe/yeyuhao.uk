---
import BaseLayout from "../layouts/BaseLayout.astro";
import MemoCard from "../components/MemoCard.astro";
import MemoHeatmap from "../components/MemoHeatmap.astro";
import MemoTagCloud from "../components/MemoTagCloud.astro";
import { getCollection, render } from "astro:content";

const allMemos = (
  await getCollection("memos", ({ data }) => data.confirmed === true)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const memosRendered = await Promise.all(
  allMemos.map(async (memo) => {
    const { Content } = await render(memo);
    return { memo, Content };
  })
);

// Tag counts
const tagMap = new Map<string, number>();
for (const { memo } of memosRendered) {
  for (const tag of memo.data.tags) {
    if (tag === "type-memo") continue;
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}
const tagCounts = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);

// Stats
const totalMemos = allMemos.length;
const activeDays = new Set(
  allMemos.map((m) => m.data.date.toISOString().slice(0, 10))
).size;

const daySet = new Set(
  allMemos.map((m) => m.data.date.toISOString().slice(0, 10))
);
let streak = 0;
const d = new Date();
while (daySet.has(d.toISOString().slice(0, 10))) {
  streak++;
  d.setDate(d.getDate() - 1);
}

const dates = allMemos.map((m) => m.data.date);
---

<BaseLayout title="碎片 — Yuho">
  <div class="memos-page">
    <!-- Sidebar -->
    <aside class="memos-sidebar">
      <!-- Stats card -->
      <div class="memo-panel">
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-num">{totalMemos}</span>
            <span class="stat-label">Memo</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{activeDays}</span>
            <span class="stat-label">天</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{streak}</span>
            <span class="stat-label">连续</span>
          </div>
        </div>
      </div>

      <!-- Heatmap -->
      <div class="memo-panel">
        <MemoHeatmap dates={dates} />
      </div>

      <!-- Tags -->
      <div class="memo-panel">
        <div class="panel-title">标签</div>
        <MemoTagCloud tagCounts={tagCounts} />
      </div>
    </aside>

    <!-- Main feed -->
    <main class="memos-feed">
      <div id="memo-feed">
        {memosRendered.map(({ memo, Content }) => (
          <MemoCard
            date={memo.data.date}
            tags={memo.data.tags.filter((t) => t !== "type-memo")}
          >
            <Content />
          </MemoCard>
        ))}
      </div>
    </main>
  </div>

  <script is:inline>
    function filterByTag(tag) {
      document.querySelectorAll("#tag-cloud .tag-btn").forEach(function (b) {
        b.classList.toggle("active", b.dataset.tag === tag);
      });
      document.querySelectorAll(".memo-card").forEach(function (card) {
        if (tag === "all") { card.style.display = ""; return; }
        var tags = JSON.parse(card.dataset.tags || "[]");
        card.style.display = tags.includes(tag) ? "" : "none";
      });
    }
    document.querySelectorAll(".tag-btn").forEach(function (btn) {
      btn.addEventListener("click", function () { filterByTag(btn.dataset.tag); });
    });
  </script>
</BaseLayout>
