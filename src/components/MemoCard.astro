---
interface Props {
  date: Date;
  tags: string[];
}

const { date, tags } = Astro.props;

const formatted = date.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});

const timeStr = date.toLocaleTimeString("zh-CN", {
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
});
---

<article class="memo-card" data-tags={JSON.stringify(tags)}>
  <div class="memo-content">
    <slot />
  </div>
  {tags.length > 0 && (
    <div class="memo-tags">
      {tags.map((tag) => (
        <a class="memo-tag tag-btn" data-tag={tag}>#{tag}</a>
      ))}
    </div>
  )}
  <div class="memo-meta">
    <time>{formatted} {timeStr}</time>
  </div>
</article>
