---
interface Props {
  dates: Date[];
}

const { dates } = Astro.props;

// Count memos per day
const countByDate = new Map<string, number>();
for (const d of dates) {
  const key = d.toISOString().slice(0, 10);
  countByDate.set(key, (countByDate.get(key) || 0) + 1);
}

// Build grid: recent 16 weeks (flomo shows ~4 months)
const weeks = 16;
const today = new Date();
const startDate = new Date(today);
startDate.setDate(startDate.getDate() - (weeks * 7 - 1) - startDate.getDay());

const cells: { date: string; count: number; col: number; row: number }[] = [];
for (let i = 0; i < weeks * 7; i++) {
  const d = new Date(startDate);
  d.setDate(d.getDate() + i);
  if (d > today) break;
  const col = Math.floor(i / 7);
  const row = i % 7;
  const key = d.toISOString().slice(0, 10);
  cells.push({ date: key, count: countByDate.get(key) || 0, col, row });
}

// Month labels
const months: { label: string; col: number }[] = [];
let lastMonth = -1;
for (const cell of cells) {
  const month = new Date(cell.date).getMonth();
  if (month !== lastMonth && cell.row === 0) {
    months.push({
      label: new Date(cell.date).toLocaleDateString("zh-CN", { month: "short" }),
      col: cell.col,
    });
    lastMonth = month;
  }
}

const cellSize = 11;
const gap = 3;
const step = cellSize + gap;
const svgWidth = weeks * step;
const svgHeight = 7 * step + 18;

function getLevel(count: number): number {
  if (count === 0) return 0;
  if (count === 1) return 1;
  if (count <= 3) return 2;
  return 3;
}
---

<div class="heatmap-wrap">
  <svg width={svgWidth} height={svgHeight} class="heatmap-svg">
    {months.map(({ label, col }) => (
      <text
        x={col * step}
        y="10"
        fill="var(--color-text-muted)"
        font-size="10"
        font-family="var(--font-sans)"
      >{label}</text>
    ))}
    <g transform="translate(0, 16)">
      {cells.map(({ date, count, col, row }) => (
        <rect
          x={col * step}
          y={row * step}
          width={cellSize}
          height={cellSize}
          rx="2"
          class={`heatmap-cell heatmap-level-${getLevel(count)}`}
          data-date={date}
          data-count={count}
        >
          <title>{date}：{count} 条</title>
        </rect>
      ))}
    </g>
  </svg>
</div>
