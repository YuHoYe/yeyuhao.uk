---
const socialLinks = [
  { href: "https://github.com/YuHoYe", label: "GitHub" },
  { href: "https://x.com/yuho_hello?s=21&t=e-tIEsn90gtar5MS_BIYXw", label: "Twitter" },
  { href: "https://xhslink.com/m/7ukN0s5pXIy", label: "小红书" },
  { href: "/rss.xml", label: "RSS" },
];
---

<footer class="border-t border-[--color-border] py-8 mt-16">
  <div class="flex items-center justify-between text-xs text-[--color-text-muted]">
    <span>&copy; {new Date().getFullYear()} Yuho</span>
    <div class="flex gap-4">
      {socialLinks.map(({ href, label }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-[--color-text-muted] no-underline hover:text-[--color-text-secondary] transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>
