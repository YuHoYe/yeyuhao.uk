---
interface Props {
  title: string;
  href: string;
  date: Date;
}

const { title, href, date } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<a href={href} class="flex items-baseline justify-between gap-4 py-2 no-underline group">
  <span class="text-sm text-[--color-text] group-hover:text-[--color-text-secondary] transition-colors">
    {title}
  </span>
  <span class="text-xs text-[--color-text-muted] shrink-0">{formattedDate}</span>
</a>
